# ─── MariaDB SOURCE (server EXISTING — jangan deploy ulang) ────────────────────
MARIADB_HOST=192.168.x.x
MARIADB_PORT=3306
MARIADB_DATABASE=prod_5_smg_mirror_ad
DEBEZIUM_DB_USER=debezium
DEBEZIUM_DB_PASSWORD=STRONG_PASSWORD_HERE

# ─── Apache Kafka EXISTING ─────────────────────────────────────────────────────
# Contoh single-broker: 192.168.x.x:9092
# Multi-broker: host1:9092,host2:9092,host3:9092
KAFKA_BOOTSTRAP=192.168.x.x:9092

# Nama topik internal Kafka Connect (harus UNIK agar tidak bentrok dg Connect lain)
CONNECT_GROUP_ID=connect-collection
CONNECT_CONFIG_TOPIC=connect-configs-collection
CONNECT_OFFSET_TOPIC=connect-offsets-collection
CONNECT_STATUS_TOPIC=connect-status-collection

# Topik schema history Debezium (1 topik khusus per connector)
SCHEMA_HISTORY_TOPIC=dbz.schema-history.collection

# ─── ClickHouse BARU ───────────────────────────────────────────────────────────
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_DATABASE=collection
CLICKHOUSE_ADMIN_USER=default
CLICKHOUSE_ADMIN_PASSWORD=STRONG_CLICKHOUSE_PASSWORD

# User read-only untuk Next.js dashboard
CLICKHOUSE_READONLY_USER=ch_readonly
CLICKHOUSE_READONLY_PASSWORD=STRONG_READONLY_PASSWORD

# ─── Next.js Dashboard ────────────────────────────────────────────────────────
# Dipakai HANYA di server-side (route handlers). Jangan ekspos ke client.
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_USER=ch_readonly
CLICKHOUSE_PASSWORD=STRONG_READONLY_PASSWORD
NEXT_PUBLIC_APP_TITLE=Collection Analytics Dashboard

# ─── Debezium server.id (harus UNIK per server di infrastruktur existing) ──────
DEBEZIUM_SERVER_ID=184

# ─── Kafka Connect worker ─────────────────────────────────────────────────────
CONNECT_HOST=connect
CONNECT_REST_PORT=8083

# ─── Dev-only: MariaDB stand-in lokal (profile "dev") ─────────────────────────
# Dipakai HANYA saat `docker compose --profile dev up`; tidak menyentuh prod.
DEV_MARIADB_ROOT_PASSWORD=devroot
DEV_MARIADB_DATABASE=prod_5_smg_mirror_ad
