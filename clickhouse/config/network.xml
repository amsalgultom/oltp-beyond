<!-- Mounting custom config.d menonaktifkan default listen_host=0.0.0.0 milik image,
     sehingga ClickHouse hanya listen di 127.0.0.1 (unreachable dari container lain). -->
<clickhouse>
    <listen_host>0.0.0.0</listen_host>
    <listen_host>::</listen_host>
    <listen_try>1</listen_try>
</clickhouse>
