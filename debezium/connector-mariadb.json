{
  "name": "src-collection-mariadb",
  "config": {
    "connector.class": "io.debezium.connector.mariadb.MariaDbConnector",
    "tasks.max": "1",

    "database.hostname": "${MARIADB_HOST}",
    "database.port": "${MARIADB_PORT}",
    "database.user": "${DEBEZIUM_DB_USER}",
    "database.password": "${DEBEZIUM_DB_PASSWORD}",
    "database.server.id": "${DEBEZIUM_SERVER_ID}",
    "database.ssl.mode": "disabled",

    "topic.prefix": "dbz.prod_5_smg_mirror_ad",
    "database.include.list": "prod_5_smg_mirror_ad",

    "table.include.list": "prod_5_smg_mirror_ad.tblAgentLoginStatus,prod_5_smg_mirror_ad.tblCallDataRecords,prod_5_smg_mirror_ad.tblCollectionResult,prod_5_smg_mirror_ad.tblCollections,prod_5_smg_mirror_ad.tblCollectionTask,prod_5_smg_mirror_ad.tblCustomerId,prod_5_smg_mirror_ad.tblUserLogs,prod_5_smg_mirror_ad.tblUserReleases",

    "schema.history.internal.kafka.bootstrap.servers": "${KAFKA_BOOTSTRAP}",
    "schema.history.internal.kafka.topic": "${SCHEMA_HISTORY_TOPIC}",

    "snapshot.mode": "schema_only",
    "snapshot.locking.mode": "minimal",

    "decimal.handling.mode": "double",
    "time.precision.mode": "connect",
    "include.schema.changes": "false",

    "event.deserialization.failure.handling.mode": "warn",

    "transforms": "unwrap",
    "transforms.unwrap.type": "io.debezium.transforms.ExtractNewRecordState",
    "transforms.unwrap.drop.tombstones": "false",
    "transforms.unwrap.delete.handling.mode": "rewrite",
    "transforms.unwrap.add.fields": "op,ts_ms,source.ts_ms",

    "key.converter": "org.apache.kafka.connect.json.JsonConverter",
    "key.converter.schemas.enable": "false",
    "value.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter.schemas.enable": "false",

    "errors.tolerance": "all",
    "errors.deadletterqueue.topic.name": "dbz.dlq.collection",
    "errors.deadletterqueue.context.headers.enable": "true"
  }
}
